# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Must be a full DSN.
DATABASE_URL=postgres://portway:portway@localhost:5432/portway?sslmode=disable

# ── Valkey (Redis-compatible) ──────────────────────────────────────────────────
# Valkey connection URL. Asynq uses this for both enqueuing and the worker.
REDIS_URL=redis://localhost:6379/0

# ── HTTP Server ───────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── GitHub App ────────────────────────────────────────────────────────────────
# The numeric App ID shown in your GitHub App's settings page.
GITHUB_APP_ID=0

# Path to the PEM private key downloaded from the GitHub App settings page.
GITHUB_PRIVATE_KEY_PATH=./github-app.pem

# Webhook secret configured in the GitHub App settings page.
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-secret

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: trace, debug, info, warn, error, fatal, panic
LOG_LEVEL=info

# ── Runtime Environment ───────────────────────────────────────────────────────
# "development" enables console-formatted logs; any other value uses JSON.
ENVIRONMENT=development
